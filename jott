#!/usr/bin/env python3
import sys
import os
from datetime import datetime

# Discover the sibling module folders for global Homebrew distribution compatibility
CURRENT_DIR = os.path.dirname(os.path.realpath(__file__))
sys.path.append(CURRENT_DIR)

from src import commands
from src.helpers import resolve_date

def main():
    if len(sys.argv) < 2:
        commands.show_status()
        commands.show_summary(datetime.now().strftime("%Y-%m-%d"))
        return
        
    cmd = sys.argv[1]
    
    if cmd in ["help", "-h", "--help"]:
        commands.show_help()
    elif cmd == "continue":
        target_id = sys.argv[2] if len(sys.argv) > 2 else None
        commands.continue_previous_task(target_id)
    elif cmd == "backlog":
        if len(sys.argv) < 4:
            print("Error: Missing parameters. Use: jott backlog [minutes] \"task description\"")
            sys.exit(1)
        try:
            minutes = int(sys.argv[2])
        except ValueError:
            print("Error: Minutes parameter must be an integer.")
            sys.exit(1)
        message = " ".join(sys.argv[3:])
        from datetime import timedelta
        commands.log_task(message, custom_dt=(datetime.now() - timedelta(minutes=minutes)))
    elif cmd in ["view", "summary"]:
        if len(sys.argv) > 2 and sys.argv[2] == "week":
            commands.show_weekly_summary()
        else:
            target_date = resolve_date(sys.argv[2]) if len(sys.argv) > 2 else datetime.now().strftime("%Y-%m-%d")
            commands.show_summary(target_date)
    elif cmd == "week":
        commands.show_weekly_summary()
    elif cmd == "status":
        commands.show_status()
    elif cmd == "sync":
        commands.sync_to_cloud()
    else:
        commands.log_task(" ".join(sys.argv[1:]))

if __name__ == "__main__":
    main()