#!/usr/bin/env python3
import sys
import os
from datetime import datetime

# ======================================================================
# HOMEBREW SYSTEM ROUTING ENVIRONMENT
# ======================================================================
# When distributed via Homebrew, the entrypoint is symlinked globally, 
# while the underlying resource files live inside an internal 'libexec' folder.
# This injection snippet discovers the true physical location of this script 
# and appends it to Python's system path so imports resolve flawlessly.
CURRENT_DIR = os.path.dirname(os.path.realpath(__file__))
sys.path.append(CURRENT_DIR)

from src import commands
from src.helpers import resolve_date

def main():
    # Fallback to default behavior if no commands or strings are supplied
    if len(sys.argv) < 2:
        commands.show_status()
        commands.show_summary(datetime.now().strftime("%Y-%m-%d"))
        return
        
    cmd = sys.argv[1]
    
    # ======================================================================
    # CLI COMMAND ROUTING MATRIX
    # ======================================================================
    if cmd in ["help", "-h", "--help"]:
        commands.show_help()
        
    elif cmd == "edit":
        # Evaluates relative tokens ('yesterday') or defaults to today's stamp
        target_date = resolve_date(sys.argv[2]) if len(sys.argv) > 2 else datetime.now().strftime("%Y-%m-%d")
        commands.edit_ledger(target_date)
        
    elif cmd == "continue":
        # Captures the optional position ID row integer argument
        target_id = sys.argv[2] if len(sys.argv) > 2 else None
        commands.continue_previous_task(target_id)
        
    elif cmd == "backlog":
        # Handles user parameter validations for retroactive task logs
        if len(sys.argv) < 4:
            print("Error: Missing parameters. Use: jott backlog [minutes] \"task description\"")
            sys.exit(1)
        try:
            minutes = int(sys.argv[2])
        except ValueError:
            print("Error: Minutes parameter must be an integer.")
            sys.exit(1)
            
        # Reconstructs the task string description from remainder arguments
        message = " ".join(sys.argv[3:])
        from datetime import timedelta
        commands.log_task(message, custom_dt=(datetime.now() - timedelta(minutes=minutes)))
        
    elif cmd in ["view", "summary"]:
        # Direct structural sub-route evaluation for week matrix views
        if len(sys.argv) > 2 and sys.argv[2] == "week":
            modifier = sys.argv[3] if len(sys.argv) > 3 else None
            commands.show_weekly_summary(modifier)
        else:
            target_date = resolve_date(sys.argv[2]) if len(sys.argv) > 2 else datetime.now().strftime("%Y-%m-%d")
            commands.show_summary(target_date)
            
    elif cmd == "week":
        # Shorthand pass-through wrapper for 'jott view week'
        modifier = sys.argv[2] if len(sys.argv) > 2 else None
        commands.show_weekly_summary(modifier)
        
    elif cmd == "status":
        commands.show_status()
        
    elif cmd == "sync":
        commands.sync_to_cloud()
        
    else:
        # Default Catch-All: If the token doesn't match a structural command, 
        # assume the user is logging a standard task directly (e.g., jott "task notes")
        commands.log_task(" ".join(sys.argv[1:]))

if __name__ == "__main__":
    main()
